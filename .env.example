DASHSCOPE_API_KEY=sk-xxxx
LESSON_DEFAULT_ASR_MODEL=sensevoice-small
DATABASE_URL=postgresql://root:password@postgres-host:5432/zeabur
# Startup now attempts Alembic automatically by default.
# Set AUTO_MIGRATE_ON_START=0 to disable it and fall back to manual migration.
AUTO_MIGRATE_ON_START=1
AUTO_MIGRATE_CONTINUE_ON_FAILURE=1
AUTO_MIGRATE_LOCK_TIMEOUT_SECONDS=180
AUTO_MIGRATE_LOCK_ID=33190114
JWT_SECRET=change-me
ADMIN_EMAILS=admin@example.com
APP_TIMEZONE=Asia/Shanghai
REDEEM_CODE_DEFAULT_VALID_DAYS=30
REDEEM_CODE_DEFAULT_DAILY_LIMIT=5
REDEEM_CODE_EXPORT_CONFIRM_TEXT=EXPORT
MT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MT_MODEL=qwen-mt-flash
PYTHONUNBUFFERED=1
TMP_WORK_DIR=/tmp/zeabur3.3
PERSISTENT_DATA_DIR=/data
FASTER_WHISPER_MODELSCOPE_MODEL_ID=pengzhendong/faster-whisper-medium
FASTER_WHISPER_MODEL_DIR=/data/modelscope_whisper/faster-whisper-medium
FASTER_WHISPER_PREFETCH_ON_START=1
FASTER_WHISPER_COMPUTE_TYPE=int8
FASTER_WHISPER_CPU_THREADS=4
ASR_SEGMENT_TARGET_SECONDS=300
ASR_SEGMENT_SEARCH_WINDOW_SECONDS=45
