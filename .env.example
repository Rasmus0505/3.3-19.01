# =============================================================================
# 环境变量示例 - 请勿在此填写真实密钥或密码
# 复制为 .env 后按实际环境修改
# =============================================================================

# -----------------------------------------------------------------------------
# 数据库
# -----------------------------------------------------------------------------
# PostgreSQL 连接串，生产环境必需。开发可省略（使用 sqlite:///./app.db）
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# -----------------------------------------------------------------------------
# DashScope / 阿里云灵积
# -----------------------------------------------------------------------------
# DashScope API 密钥，用于 ASR（语音识别）及 MT（机器翻译）。使用 qwen3-asr 或 MT 时必需
DASHSCOPE_API_KEY=sk-your-api-key-here

# -----------------------------------------------------------------------------
# 应用运行环境
# -----------------------------------------------------------------------------
# 应用环境：development | test | prod | production。影响 DATABASE_URL 校验等
APP_ENV=development
# 应用时区
APP_TIMEZONE=Asia/Shanghai

# -----------------------------------------------------------------------------
# JWT / 认证（app/security.py）
# -----------------------------------------------------------------------------
# JWT 签名密钥，生产必须改为强密钥
JWT_SECRET=dev-only-change-me
# Access Token 过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=120
# Refresh Token 过期天数
REFRESH_TOKEN_EXPIRE_DAYS=15

# -----------------------------------------------------------------------------
# 管理后台
# -----------------------------------------------------------------------------
# 首次启动时的管理员引导密码（可选，需符合强度要求）
ADMIN_BOOTSTRAP_PASSWORD=
# 管理员邮箱白名单，逗号分隔（可选）
ADMIN_EMAILS=

# -----------------------------------------------------------------------------
# 临时工作目录
# -----------------------------------------------------------------------------
# 临时与工作文件根目录，默认 /tmp/zeabur3.3
TMP_WORK_DIR=/tmp/zeabur3.3
# 持久化数据目录（课程工作区、媒体等），Windows 默认 temp，Linux 默认 /data
PERSISTENT_DATA_DIR=/data

# -----------------------------------------------------------------------------
# 课程与 ASR 配置
# -----------------------------------------------------------------------------
# 默认 ASR 模型：qwen3-asr-flash-filetrans 等
LESSON_DEFAULT_ASR_MODEL=qwen3-asr-flash-filetrans
# 是否启用 Qwen ASR（1/0 或 true/false）
QWEN_ASR_ENABLED=1
# ASR 分段时间目标（秒）
ASR_SEGMENT_TARGET_SECONDS=300
# ASR 分段搜索窗口（秒）
ASR_SEGMENT_SEARCH_WINDOW_SECONDS=45
# ASR 任务轮询间隔（秒）
ASR_TASK_POLL_SECONDS=2
# 课程最大并发任务数
LESSON_TASK_MAX_ACTIVE=4
# 课程最大排队任务数
LESSON_TASK_MAX_QUEUED=8

# -----------------------------------------------------------------------------
# Faster-Whisper 本地 ASR
# -----------------------------------------------------------------------------
# ASR 模型捆绑根目录
ASR_BUNDLE_ROOT_DIR=./asr-test/models
# Faster-Whisper 模型目录（完整路径）
FASTER_WHISPER_MODEL_DIR=/data/faster-whisper-models
# ModelScope 模型 ID
FASTER_WHISPER_MODELSCOPE_MODEL_ID=Systran/faster-distil-whisper-small.en
# 是否启动时预加载模型
FASTER_WHISPER_PREFETCH_ON_START=false
# 计算类型：int8、float16 等
FASTER_WHISPER_COMPUTE_TYPE=int8
# CPU 线程数
FASTER_WHISPER_CPU_THREADS=4

# -----------------------------------------------------------------------------
# 机器翻译（MT）
# -----------------------------------------------------------------------------
# MT API 基地址
MT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# MT 模型名（当前强制 qwen-mt-flash）
MT_MODEL=qwen-mt-flash
# MT 请求超时（秒）
MT_TIMEOUT_SECONDS=20
# MT 单批最大字符数
MT_BATCH_MAX_CHARS=2600
# MT 最小请求间隔（毫秒）
MT_MIN_REQUEST_INTERVAL_MS=600
# MT 重试最大次数
MT_RETRY_MAX_ATTEMPTS=4

# -----------------------------------------------------------------------------
# 兑换码
# -----------------------------------------------------------------------------
# 导出兑换码确认短语（需符合强度要求）
REDEEM_CODE_EXPORT_CONFIRM_TEXT=EXPORT
# 兑换码默认有效天数
REDEEM_CODE_DEFAULT_VALID_DAYS=30
# 兑换码默认每日使用上限
REDEEM_CODE_DEFAULT_DAILY_LIMIT=5

# -----------------------------------------------------------------------------
# 启动与部署
# -----------------------------------------------------------------------------
# 是否启动时自动执行数据库迁移（1/0 或 true/false）
AUTO_MIGRATE_ON_START=1
# 服务监听端口
PORT=8080
# Alembic 配置文件路径
ALEMBIC_CONFIG=alembic.ini

# -----------------------------------------------------------------------------
# 桌面/离线环境（可选）
# -----------------------------------------------------------------------------
# 预装或捆绑 ASR 模型目录
DESKTOP_PREINSTALLED_MODEL_DIR=
DESKTOP_BUNDLED_MODEL_DIR=
# 安装状态文件路径
DESKTOP_INSTALL_STATE_PATH=
# FFmpeg 可执行目录
DESKTOP_FFMPEG_BIN_DIR=
# yt-dlp 可执行路径
DESKTOP_YTDLP_PATH=
