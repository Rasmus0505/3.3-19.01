APP_ENV=development
DASHSCOPE_API_KEY=sk-xxxx
# Supported upload ASR models: faster-whisper-medium, qwen3-asr-flash-filetrans
LESSON_DEFAULT_ASR_MODEL=qwen3-asr-flash-filetrans
DATABASE_URL=postgresql://root:password@postgres-host:5432/zeabur
# Recommended for local-agent production migrations. Keep this separate from local dev when possible.
PROD_DATABASE_URL=postgresql://root:password@47.108.142.28:30835/zeabur
# Prefer manual/local-agent migrations for production deploys.
AUTO_MIGRATE_ON_START=0
AUTO_MIGRATE_CONTINUE_ON_FAILURE=1
AUTO_MIGRATE_LOCK_TIMEOUT_SECONDS=180
AUTO_MIGRATE_LOCK_ID=33190114
JWT_SECRET=change-me
# Bootstrap admins into the database on first deploy.
ADMIN_EMAILS=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=replace-with-a-long-random-passphrase
APP_TIMEZONE=Asia/Shanghai
REDEEM_CODE_DEFAULT_VALID_DAYS=30
REDEEM_CODE_DEFAULT_DAILY_LIMIT=5
REDEEM_CODE_EXPORT_CONFIRM_TEXT=replace-with-a-long-random-confirmation-phrase
MT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MT_MODEL=qwen-mt-flash
PYTHONUNBUFFERED=1
TMP_WORK_DIR=/tmp/zeabur3.3
PERSISTENT_DATA_DIR=/data
ASR_BUNDLE_ROOT_DIR=/data/asr-models
# Optional server-side Bottle 1.0 bundle path. Bottle 2.0 only needs DASHSCOPE_API_KEY.
FASTER_WHISPER_MODELSCOPE_MODEL_ID=Systran/faster-distil-whisper-small.en
FASTER_WHISPER_MODEL_DIR=/data/asr-models/faster-distil-small.en
FASTER_WHISPER_PREFETCH_ON_START=0
FASTER_WHISPER_COMPUTE_TYPE=int8
FASTER_WHISPER_CPU_THREADS=4
ASR_SEGMENT_TARGET_SECONDS=300
ASR_SEGMENT_SEARCH_WINDOW_SECONDS=45
