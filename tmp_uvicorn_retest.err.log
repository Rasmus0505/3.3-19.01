', 'punctuation': '', 'begin_time': 300945, 'end_time': 301165}, {'text': 'each', 'surface': 'each', 'punctuation': '', 'begin_time': 301165, 'end_time': 301345}, {'text': 'other', 'surface': 'other.', 'punctuation': '.', 'begin_time': 301345, 'end_time': 301625}, {'text': 'remember', 'surface': 'remember', 'punctuation': '', 'begin_time': 301765, 'end_time': 302065}, {'text': 'the', 'surface': 'the', 'punctuation': '', 'begin_time': 302065, 'end_time': 302105}, {'text': 'first', 'surface': 'first', 'punctuation': '', 'begin_time': 302105, 'end_time': 302445}, {'text': 'time', 'surface': 'time', 'punctuation': '', 'begin_time': 302445, 'end_time': 302645}, {'text': 'Claire', 'surface': 'Claire', 'punctuation': '', 'begin_time': 302645, 'end_time': 302905}, {'text': 'brought', 'surface': 'brought', 'punctuation': '', 'begin_time': 302905, 'end_time': 303105}, {'text': 'me', 'surface': 'me', 'punctuation': '', 'begin_time': 303105, 'end_time': 303305}, {'text': 'home', 'surface': 'home.', 'punctuation': '.', 'begin_time': 303305, 'end_time': 303745}, {'text': 'Do', 'surface': 'Do', 'punctuation': '', 'begin_time': 304865, 'end_time': 304925}, {'text': 'you', 'surface': 'you', 'punctuation': '', 'begin_time': 304925, 'end_time': 305045}, {'text': 'think', 'surface': 'think', 'punctuation': '', 'begin_time': 305045, 'end_time': 305165}, {'text': 'Jay', 'surface': 'Jay', 'punctuation': '', 'begin_time': 305165, 'end_time': 305445}, {'text': 'thought', 'surface': 'thought', 'punctuation': '', 'begin_time': 305445, 'end_time': 305665}, {'text': 'I', 'surface': 'I', 'punctuation': '', 'begin_time': 305665, 'end_time': 305785}, {'text': 'was', 'surface': 'was', 'punctuation': '', 'begin_time': 305785, 'end_time': 305945}, {'text': 'good', 'surface': 'good', 'punctuation': '', 'begin_time': 305945, 'end_time': 306085}, {'text': 'enough', 'surface': 'enough', 'punctuation': '', 'begin_time': 306085, 'end_time': 306305}, {'text': 'for', 'surface': 'for', 'punctuation': '', 'beg