{
  "name": "bottle-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Bottle Desktop - 本地 AI 课程生成器",
  "main": "./out/main/main.js",
  "type": "module",
  "author": "Bottle",
  "scripts": {
    "dev": "electron-vite dev --config electron-vite.config.ts",
    "build": "electron-vite build --config electron-vite.config.ts",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "package:win": "npm run build && electron-builder --win --config electron-builder.json",
    "package:win:dir": "npm run build && electron-builder --win --dir --config electron-builder.json"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "electron-log": "^5.3.0",
    "electron-updater": "^6.3.9",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.1",
    "sherpa-onnx-node": "^1.12.33",
    "sonner": "^2.0.7",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "electron": "^33.4.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^5.4.0"
  },
  "build": {
    "extends": "electron-builder.json"
  }
}
